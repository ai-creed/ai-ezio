{
	"name": "ai-ezio-monorepo",
	"version": "0.1.0",
	"private": true,
	"description": "ai-ezio: hax-derived, workflow-native coding agent (monorepo root)",
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc --build",
		"clean": "tsc --build --clean",
		"typecheck": "tsc --build",
		"test": "pnpm -r --workspace-concurrency=1 test",
		"lint": "eslint .",
		"format": "prettier --write \"packages/**/*.{ts,json}\" \"packaging/**/*.json\"",
		"format:check": "prettier --check \"packages/**/*.{ts,json}\" \"packaging/**/*.json\"",
		"smoke:install": "node scripts/smoke-install.mjs"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"@typescript-eslint/eslint-plugin": "^8.18.0",
		"@typescript-eslint/parser": "^8.18.0",
		"eslint": "^9.17.0",
		"prettier": "^3.4.0",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0"
	}
}
