{
	"name": "ai-ezio-monorepo",
	"version": "0.0.0",
	"private": true,
	"description": "ai-ezio: hax-derived, workflow-native coding agent (monorepo root)",
	"license": "MIT",
	"type": "module",
	"packageManager": "pnpm@9.12.0",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc --build",
		"clean": "tsc --build --clean",
		"typecheck": "tsc --build",
		"test": "pnpm -r --workspace-concurrency=1 test",
		"lint": "eslint .",
		"format": "prettier --write \"packages/**/*.{ts,json}\" \"packaging/**/*.json\"",
		"format:check": "prettier --check \"packages/**/*.{ts,json}\" \"packaging/**/*.json\"",
		"smoke:install": "node scripts/smoke-install.mjs",
		"smoke:proto": "node scripts/proto-smoke.mjs",
		"smoke:cli-mount": "node scripts/cli-mount-smoke.mjs",
		"smoke:bootstrap": "node scripts/bootstrap-smoke.mjs",
		"check:pack": "node scripts/check-pack-manifest.mjs",
		"check:binaries": "node scripts/check-platform-binaries.mjs"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"esbuild": "^0.28.1",
		"eslint": "^9.17.0",
		"prettier": "^3.4.0",
		"typescript": "^5.7.0",
		"typescript-eslint": "^8.18.0",
		"vitest": "^4.1.8"
	},
	"pnpm": {
		"overrides": {
			"esbuild": "^0.28.1",
			"hono": "^4.12.25"
		}
	}
}
