# dependencies
node_modules/
.pnpm-store/

# build output
dist/
build/
*.tsbuildinfo

# vendored hax C build trees (submodule builds locally)
vendor/hax/build/
vendor/hax/build-asan/

# packaged single-binary artifacts
artifacts/
*.node

# staged per-platform hax binaries (build artifacts; populated by the CI
# cross-compile matrix or scripts/stage-host-binary.mjs — never committed)
packaging/*/bin/

# temporary idea docs (scratch notes; not published)
docs/superpowers/ideas/

# implementation plans (local guide for agents; canonical copy lives in
# ~/.ai-pref-nsync/local-docs). Specs ARE committed; plans are not.
docs/superpowers/plans/

# manual smoke checklists (local QA scratch; not published)
docs/smoke/

# logs / debug (hax HAX_TRACE / HAX_TRANSCRIPT dumps)
*.log
.DS_Store

# editor / OS
.idea/
.vscode/
*.swp
