{
	"name": "ai-ezio",
	"version": "0.1.0-beta.0",
	"description": "ai-ezio: hax-derived, workflow-native coding agent",
	"license": "MIT",
	"type": "module",
	"bin": {
		"ai-ezio": "bin/ai-ezio.mjs",
		"ezio": "bin/ai-ezio.mjs"
	},
	"haxBaseCommit": "8fd139b5db49bd0b1d552c2530a18b547b3f4f4c",
	"exports": {
		".": {
			"types": "./dist/cli.d.ts",
			"import": "./dist/cli.js"
		}
	},
	"files": [
		"dist",
		"bin"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc --build && node ../../scripts/bundle.mjs",
		"test": "vitest run",
		"prepack": "node ../../scripts/make-publish-manifest.mjs",
		"postpack": "node ../../scripts/make-publish-manifest.mjs restore"
	},
	"optionalDependencies": {
		"@ai-ezio/hax-darwin-arm64": "workspace:*",
		"@ai-ezio/hax-darwin-x64": "workspace:*",
		"@ai-ezio/hax-linux-x64": "workspace:*",
		"@ai-ezio/hax-linux-arm64": "workspace:*"
	},
	"devDependencies": {
		"@ai-ezio/harness": "workspace:*",
		"@ai-ezio/mcp-host": "workspace:*",
		"@ai-ezio/protocol": "workspace:*",
		"@ai-ezio/session-recorder": "workspace:*",
		"@ai-ezio/surface": "workspace:*"
	}
}
